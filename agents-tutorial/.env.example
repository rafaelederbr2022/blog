# === LLM Provider Selection ===
# Valid values: "openai" or "bedrock" (default: openai)
LLM_PROVIDER=openai

# === Required ===
OPENAI_API_KEY=sk-...

# === LangSmith (Module 6+) ===
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=langchain-study
LANGCHAIN_TRACING_V2=true

# === Database (Module 6) ===
POSTGRES_URL=postgresql://user:pass@localhost:5432/langchain_study
REDIS_URL=redis://localhost:6379/0

# === Google ADK (Module 11) ===
GOOGLE_API_KEY=...

# === DeepEval (Module 12) ===
DEEPEVAL_API_KEY=...

# === Optional Settings ===
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.7

# === AWS Bedrock (when LLM_PROVIDER=bedrock) ===
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDINGS_MODEL_ID=amazon.titan-embed-text-v2:0
# AWS credentials (prefer IAM roles in production)
AWS_ACCESS_KEY_ID=XXXX...
AWS_SECRET_ACCESS_KEY=YYYY...
